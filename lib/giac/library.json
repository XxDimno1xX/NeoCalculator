{
  "name": "giac",
  "version": "1.9.0",
  "description": "Giac CAS engine for NumOS",
  "build": {
    "flags": [
      "-DGIAC_KHICAS",
      "-DNO_GUI",
      "-DGIAC_GENERIC",
      "-DEMBEDDED",
      "-DUMAP",
      "-fexceptions",
      "-frtti",
      "-Isrc"
    ],
    "srcFilter": [
      "+<src/>",
      "+<src/**/*.cpp>",
      "+<src/**/*.c>",
      "+<**/*.cpp>",
      "+<**/*.c>",
      "-<src/test.cpp>",
      "-<src/Xcas*>",
      "-<src/Fl_*>"
    ]
  },
  "dependencies": {
    "libtommath": "*"
  }
}