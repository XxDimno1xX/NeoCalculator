# grapher_classifier_basic_smoke — GR-02/GR-14: kind classification of the
# explicit MVP forms, asserted semantically (no pixels).
#   slot 0: "y=x"  → explicitY (y = f(x))
#   slot 1: "x"    → bare expression, behaves as y=x → explicitY
# Both must be valid; the committed serialized text is asserted exactly.
#
# Run:
#   program --script tests/emulator/scripts/grapher_classifier_basic_smoke.numos \
#           --deterministic --frames 1400 --headless
wait 200
open_app Grapher
wait 60
key down
key enter
key y
key =
key x
key enter
wait 40
key down
key enter
key x
key enter
wait 60
assert_app Grapher
assert_graph_relation_count 2
assert_graph_slot_kind 0 explicitY
assert_graph_slot_valid 0
assert_graph_expr_text 0 y=x
assert_graph_relation_op 0 eq
assert_graph_slot_kind 1 explicitY
assert_graph_slot_valid 1
assert_graph_expr_text 1 x
log "classifier_basic: y=x and bare x are explicitY"
