# grapher_aspect_circle_smoke.numos — Phase 10C. Plot the unit circle
# x^2 + y^2 = 1 and zoom in so it fills the view. With equal-aspect (square-grid)
# rendering this must appear as a TRUE CIRCLE, not a horizontally stretched oval.
# Warning-only (screenshot, no golden).
log "aspect circle: start"
wait 200
open_app Grapher
wait 60
key down
key enter
# Type "x^2+y^2=1"
key x
key ^
key 2
key right
key +
key y
key ^
key 2
key right
key =
key 1
key enter
wait 80
key graph
wait 80
# TRACE -> NAVIGATE, then zoom in 3x (centered on origin).
key ac
key zoom
key zoom
key zoom
wait 150
screenshot out/grapher_aspect_circle_smoke.ppm
assert_app Grapher
log "aspect circle: x^2+y^2=1 plotted"
