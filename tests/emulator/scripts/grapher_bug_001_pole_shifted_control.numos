# grapher_bug_001_pole_shifted_control — positive control for GRBUG-001.
# y=1/(x-1) has the same shape as y=1/x but its pole at x=1 does NOT sit on the
# viewport centre / sample grid, so it rendered correctly both before and after
# the fix. This pins the control: classification, graph and zoom must stay
# healthy, proving the pole-zero fix did not disturb the off-centre case.
#
# Warning-only screenshot to gitignored out/ — NOT a blessed golden.
#
# Run:
#   program --script tests/emulator/scripts/grapher_bug_001_pole_shifted_control.numos \
#           --deterministic --frames 1400 --headless --quiet
log "grapher_bug_001_pole_shifted_control: start"
wait 200
open_app Grapher
wait 60
key down
key enter
key y
key =
key 1
key /
key x
key -
key 1
key enter
wait 60
assert_graph_relation_count 1
assert_graph_slot_kind 0 explicitY
assert_graph_slot_valid 0
assert_graph_expr_text 0 y=(1)/(x-1)
key graph
wait 100
assert_app Grapher
assert_graph_trace_state trace
key zoom
wait 60
assert_app Grapher
screenshot out/grapher_bug_001_pole_shifted_control.ppm
wait 5
key home
wait 80
assert_app Menu
log "grapher_bug_001_pole_shifted_control: y=1/(x-1) healthy through graph + zoom"
