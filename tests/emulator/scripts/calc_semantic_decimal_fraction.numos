# calc_semantic_decimal_fraction.numos — decimal literals convert to EXACT fractions.
#
# Phase 8D semantic smoke. NO screenshot, NO golden.
#
# Verifies the Phase 8D decimal-point input fix: typing a decimal point now lands
# in the number node, and MathEvaluator::evalNumber converts the decimal literal to
# an EXACT rational (e.g. 0.5 -> 1/2, 0.25 -> 1/4) via integer arithmetic — no
# floating-point rounding. This stays strictly in the small-int / exact-fraction
# domain (no approximate output), so the assertions are byte-stable.
#
#   0.5 + 0.25  -> 1/2 + 1/4 -> exact 3/4
#   1.5 + 1/2   -> 3/2 + 1/2 -> exact 2   (decimal mixed with a VPAM fraction)
#
# AC is used between the two evaluations because clearResult() keeps the previous
# expression (see calc_semantic_ans_chain.numos for the rationale).
#
# Run: program --headless --deterministic --script <this> --frames 1400 --quiet
# Exit codes: 0 ok · 2 parse · 3 screenshot · 4 assertion failure.

log "calc_semantic_decimal_fraction: waiting for launcher"
wait 200
open_app Calculation
wait 60

# 0.5 + 0.25 -> exact 3/4
key 0
key .
key 5
key +
key 0
key .
key 2
key 5
key ENTER
wait 120

assert_app Calculation
assert_no_error
assert_result 3/4

# Fresh expression, then 1.5 + 1/2 -> exact 2 (decimal + VPAM fraction).
key ac
wait 30
key 1
key .
key 5
key +
key 1
key FRAC
key 2
key RIGHT
key ENTER
wait 120

assert_no_error
assert_result 2
log "calc_semantic_decimal_fraction: PASS (0.5+0.25==3/4, 1.5+1/2==2)"
