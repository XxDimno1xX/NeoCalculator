# grapher_aspect_sin_smoke.numos — Phase 10C. Plot sin(x) at the default equal-
# aspect view to confirm explicit transcendental functions still render correctly
# after the square-grid change. Warning-only (screenshot, no golden).
log "aspect sin: start"
wait 200
open_app Grapher
wait 60
key down
key enter
key y
key =
key sin
key x
key enter
wait 80
key graph
wait 80
key ac
key 0
wait 120
screenshot out/grapher_aspect_sin_smoke.ppm
assert_app Grapher
log "aspect sin: sin(x) plotted"
