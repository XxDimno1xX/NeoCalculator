# grapher_implicit_sideways_smoke.numos — Phase 10B. Plot the IMPLICIT equation
# x = y^2 (a parabola opening to the RIGHT) — a function of y, impossible for the
# single-valued y=f(x) sampler. Proves implicit detection routes "x = <expr in y>"
# to the marching-squares contour renderer. Warning-only (no golden).
log "implicit sideways parabola: start"
wait 200
open_app Grapher
wait 60
key down
key enter
# Type "x=y^2"
key x
key =
key y
key ^
key 2
key enter
wait 80
key graph
wait 80
key zoom
key zoom
wait 150
screenshot out/grapher_implicit_sideways_smoke.ppm
assert_app Grapher
log "implicit sideways parabola: x=y^2 plotted"
